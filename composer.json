{
    "name": "sms-partners/sms-partners-php",
    "description": "Official PHP SDK for the SMS Partners API.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "pestphp/pest": "^2.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "SmsPartners\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SmsPartners\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
